// ================================================================
// JYF's Blog — Refined Aesthetic Styles
// 笔墨 · 游记 · 克制之美
// ================================================================


// ----------------------------------------------------------------
// 1. Post Body — 阅读节奏
// ----------------------------------------------------------------

.post-body
  line-height: 1.95
  letter-spacing: 0.02em

// ----------------------------------------------------------------
// 2. Headings — 章节结构
// ----------------------------------------------------------------

.post-body h1,
.post-body h2,
.post-body h3,
.post-body h4,
.post-body h5,
.post-body h6
  letter-spacing: 0.04em

// h2 作为章节分隔线，带墨色底边
.post-body h2
  padding-bottom: 0.45em
  border-bottom: 1px solid rgba(0, 0, 0, 0.1)

html[data-theme="dark"] .post-body h2
  border-bottom-color: rgba(255, 255, 255, 0.1)

// ----------------------------------------------------------------
// 3. Blockquotes — 文学批注
// ----------------------------------------------------------------

.post-body blockquote
  position: relative
  margin: 2em 0
  padding: 1.1em 1.6em
  border-left: 3px solid #5b9bd5
  background: rgba(91, 155, 213, 0.06)
  border-radius: 0 8px 8px 0
  font-style: normal

  p
    margin: 0
    line-height: 1.9

html[data-theme="dark"] .post-body blockquote
  border-left-color: #3a6a9b
  background: rgba(58, 106, 155, 0.1)

// ----------------------------------------------------------------
// 4. Horizontal Rules — 笔墨分隔
// ----------------------------------------------------------------

.post-body hr
  border: none
  margin: 3em auto
  width: 60%
  height: 1px
  background: linear-gradient(to right, transparent, rgba(0, 0, 0, 0.18), transparent)

html[data-theme="dark"] .post-body hr
  background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.15), transparent)

// ----------------------------------------------------------------
// 5. Images — 画框质感
// ----------------------------------------------------------------

.post-body img
  border-radius: 6px
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08)
  transition: box-shadow 0.3s ease

.post-body img:hover
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15)

html[data-theme="dark"] .post-body img:hover
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5)

// ----------------------------------------------------------------
// 6. Tables — 整洁排版
// ----------------------------------------------------------------

.post-body table
  border-collapse: collapse
  width: 100%
  margin: 1.6em 0
  font-size: 0.95em

.post-body table th
  background: rgba(0, 0, 0, 0.04)
  font-weight: 700
  letter-spacing: 0.04em

.post-body table th,
.post-body table td
  padding: 0.7em 1.1em
  border: 1px solid rgba(0, 0, 0, 0.1)

html[data-theme="dark"] .post-body table th
  background: rgba(255, 255, 255, 0.06)

html[data-theme="dark"] .post-body table th,
html[data-theme="dark"] .post-body table td
  border-color: rgba(255, 255, 255, 0.1)

// 代码块内部表格重置，避免被上面的表格样式污染
.post-body .highlight table,
.post-body figure.highlight table
  border-collapse: initial
  width: auto
  margin: 0
  font-size: inherit

.post-body .highlight table th,
.post-body .highlight table td,
.post-body figure.highlight table th,
.post-body figure.highlight table td
  padding: 0
  border: none
  background: none

// ----------------------------------------------------------------
// 7. Tag Cloud — 墨格标牌
// ----------------------------------------------------------------

.tag-cloud-tags
  margin-top: 60px
  display: flex
  flex-wrap: wrap
  justify-content: center
  gap: 16px

.tag-cloud-tags a
  display: flex !important
  align-items: center
  justify-content: center

  width: 96px
  height: 96px

  background: #fafaf8
  border: 1px solid rgba(0, 0, 0, 0.07)
  border-radius: 18px

  font-size: 15px !important
  font-weight: 600
  color: #3a3a3a !important
  letter-spacing: 0.05em

  border-bottom: none !important
  text-decoration: none

  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.8)
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1)

.tag-cloud-tags a small,
.tag-cloud-tags a span
  display: none !important

.tag-cloud-tags a:hover
  background: #2a2a2a
  color: #f0ede8 !important
  transform: translateY(-7px) scale(1.04)
  box-shadow: 0 16px 30px rgba(0, 0, 0, 0.18), 0 4px 8px rgba(0, 0, 0, 0.1)
  border-color: transparent

html[data-theme="dark"] .tag-cloud-tags a
  background: rgba(255, 255, 255, 0.04)
  border-color: rgba(255, 255, 255, 0.09)
  color: #e0ddd8 !important
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.04)

html[data-theme="dark"] .tag-cloud-tags a:hover
  background: rgba(255, 255, 255, 0.12)
  color: #f0ede8 !important
  box-shadow: 0 16px 30px rgba(0, 0, 0, 0.4)

// ----------------------------------------------------------------
// 8. Post Button — 低调邀请
// ----------------------------------------------------------------

.post-button .btn
  display: inline-block
  background: transparent
  color: #555
  border: 1.5px solid rgba(0, 0, 0, 0.2)
  border-radius: 999px
  padding: 7px 32px
  font-size: 13px
  letter-spacing: 0.12em
  transition: all 0.28s ease

.post-button .btn:hover
  background: #2a2a2a
  color: #f0ede8
  border-color: #2a2a2a
  transform: translateY(-2px)
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.14)

html[data-theme="dark"] .post-button .btn
  color: #ccc
  border-color: rgba(255, 255, 255, 0.2)

html[data-theme="dark"] .post-button .btn:hover
  background: rgba(255, 255, 255, 0.12)
  color: #f0ede8
  border-color: rgba(255, 255, 255, 0.35)
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.35)

// ----------------------------------------------------------------
// 9. Sidebar TOC — 章节导航
// ----------------------------------------------------------------

.sidebar-inner .post-toc
  font-size: 13px

.sidebar-inner .post-toc .toc-link
  border-bottom: none
  opacity: 0.6
  transition: opacity 0.2s ease, padding-left 0.2s ease

.sidebar-inner .post-toc .toc-link:hover
  opacity: 1
  padding-left: 4px

.sidebar-inner .post-toc .toc-link.active
  opacity: 1
  font-weight: 600

// ----------------------------------------------------------------
// 10. Selection Highlight — 朱砂批注
// ----------------------------------------------------------------

::selection
  background: rgba(201, 169, 110, 0.28)
  color: inherit

html[data-theme="dark"] ::selection
  background: rgba(138, 106, 58, 0.45)

// ----------------------------------------------------------------
// 11. Black Night Theme — 深黑配色覆盖
// Always-dark: override NexT's dark theme vars to near-black values.
// Our stylesheet loads after NexT's, so these take precedence.
// ----------------------------------------------------------------

html[data-theme="dark"]
  --body-bg-color: #050505
  --content-bg-color: #0f0f0f
  --card-bg-color: #161616
  --navbar-bg-color: #000000
  --sidebar-bg-color: #090909
  --border-color: rgba(255, 255, 255, 0.06)
  --text-color: #e8e8e8
  --link-color: #c8c4bc
  --link-hover-color: #f0f0f0

// ----------------------------------------------------------------
// 12. Dark Mode Code — 代码高亮修正
// ----------------------------------------------------------------

// 行内代码
html[data-theme="dark"] code
  color: #e8e8e8
  background: rgba(255, 255, 255, 0.08)

// 代码块内文字（未被高亮主题覆盖的部分）
html[data-theme="dark"] .highlight,
html[data-theme="dark"] .code-container
  color: #e8e8e8

// ----------------------------------------------------------------
// 13. Sidebar Nav Active — 蓝色导航高亮
// ----------------------------------------------------------------

.sidebar-toc-active .sidebar-nav-toc,
.sidebar-overview-active .sidebar-nav-overview
  border-bottom-color: #4da6ff !important
  color: #4da6ff !important

.post-toc .nav .active > a,
.post-toc .nav .active-current > a
  border-bottom-color: #4da6ff !important
  color: #4da6ff !important

